---
import { site } from '../content/site';

const navLinks = [
  { label: 'Services',    href: '#services'    },
  { label: 'How We Work', href: '#how-we-work'  },
  { label: 'Why Benfort', href: '#why-benfort'  },
  { label: 'Contact',     href: '#contact'      },
];
---
<footer class="bg-dark-navy text-ice/70" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-16">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo: invert the colour PNG to white for the dark footer -->
        <img
          src="/benfort marketing.png"
          alt="Benfort Marketing"
          class="h-8 w-auto mb-4"
          style="filter: brightness(0) invert(1);"
          loading="lazy"
        />
        <p class="text-ice/60 text-sm leading-body max-w-xs mb-5">
          {site.tagline} Based in Zimbabwe, built for Africa.
        </p>
        <div class="flex gap-3">
          <a
            href={site.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-dark2 hover:bg-brand-green flex items-center justify-center
                   transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-brand-green"
            aria-label="WhatsApp"
          >
            <svg class="w-4 h-4 text-ice" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
          <a
            href={`mailto:${site.email}`}
            class="w-9 h-9 rounded-lg bg-dark2 hover:bg-brand-blue flex items-center justify-center
                   transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-brand-blue"
            aria-label="Email us"
          >
            <svg class="w-4 h-4 text-ice" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4 uppercase tracking-widest text-xs">Navigation</h3>
        <ul class="flex flex-col gap-2.5" role="list">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-ice/60 hover:text-brand-green transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4 uppercase tracking-widest text-xs">Contact</h3>
        <ul class="flex flex-col gap-2.5 text-sm" role="list">
          <li>
            <a href={`mailto:${site.email}`} class="text-ice/60 hover:text-brand-green transition-colors duration-200 break-all">
              {site.email}
            </a>
          </li>
          <li>
            <a href={site.whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-ice/60 hover:text-brand-green transition-colors duration-200">
              {site.whatsapp}
            </a>
          </li>
          <li class="text-ice/60">{site.location}</li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-dark2 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-ice/40">
        © {site.year} Benfort Marketing. All rights reserved.
      </p>
      <p class="text-xs text-ice/30 flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-green" aria-hidden="true"></span>
        Built by Benfort
      </p>
    </div>

  </div>
</footer>

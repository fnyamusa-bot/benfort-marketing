---
import { site } from '../content/site';
---
<section
  class="relative bg-dark-navy py-24 lg:py-32 overflow-hidden"
  aria-label="Call to action"
>
  <!-- Decorative circles -->
  <div class="absolute -right-32 -top-32 w-[500px] h-[500px] rounded-full bg-dark2 opacity-70" aria-hidden="true"></div>
  <div class="absolute -left-20 -bottom-20 w-[280px] h-[280px] rounded-full bg-dark2 opacity-50" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <div data-animate>
      <span class="inline-flex items-center gap-2 bg-dark2 border border-ice/10 text-ice/70 text-xs font-medium px-4 py-1.5 rounded-full mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-green" aria-hidden="true"></span>
        Ready to start?
      </span>
    </div>

    <h2
      class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-black text-white tracking-display leading-tight mb-6"
      data-animate data-delay="100"
    >
      {site.ctaLine}
    </h2>
    <p
      class="text-ice/70 text-lg leading-body max-w-xl mx-auto mb-10"
      data-animate data-delay="200"
    >
      {site.ctaSub}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate data-delay="300">
      <a
        href="#contact"
        class="inline-flex items-center justify-center gap-2 bg-brand-green text-white px-8 py-3.5 rounded-xl font-semibold text-base
               hover:bg-emerald-500 focus-visible:ring-2 focus-visible:ring-brand-green focus-visible:ring-offset-2 focus-visible:ring-offset-dark-navy
               transition-colors duration-200 active:scale-95 shadow-lg shadow-brand-green/30"
      >
        Book a free consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <a
        href={site.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 border border-white/20 text-white px-8 py-3.5 rounded-xl font-semibold text-base
               hover:bg-white/10 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-dark-navy
               transition-colors duration-200 active:scale-95"
      >
        <!-- WhatsApp icon -->
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        WhatsApp us
      </a>
    </div>

    <p class="mt-8 text-ice/50 text-sm" data-animate data-delay="400">
      Or email us directly at{' '}
      <a
        href={`mailto:${site.email}`}
        class="text-ice/80 hover:text-brand-green underline underline-offset-2 transition-colors"
      >
        {site.email}
      </a>
    </p>

  </div>
</section>

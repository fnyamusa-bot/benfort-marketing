---
import { site } from '../content/site';

// TODO: Replace with your actual Formspree endpoint
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xkolgwvg';

const serviceOptions = site.services.map(s => s.name);
---
<section id="contact" class="bg-light py-24 lg:py-32" aria-labelledby="contact-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: info -->
      <div data-animate>
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-brand-green" aria-hidden="true"></span>
          <span class="text-brand-green font-semibold text-sm uppercase tracking-widest">Get in touch</span>
        </div>
        <h2
          id="contact-heading"
          class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink tracking-display leading-tight mb-6"
        >
          Let's build something smarter.
        </h2>
        <p class="text-brand-grey text-lg leading-body mb-10">
          Tell us about your business and what you'd like to improve. We'll come back with ideas and a clear quote — no obligation.
        </p>

        <div class="flex flex-col gap-5">
          <!-- Email -->
          <a
            href={`mailto:${site.email}`}
            class="flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-brand-blue/8 flex items-center justify-center flex-shrink-0
                        group-hover:bg-brand-blue transition-colors duration-200">
              <svg class="w-5 h-5 text-brand-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-grey font-medium uppercase tracking-widest mb-0.5">Email</p>
              <p class="text-ink font-semibold group-hover:text-brand-blue transition-colors">{site.email}</p>
            </div>
          </a>

          <!-- WhatsApp -->
          <a
            href={site.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-brand-green/10 flex items-center justify-center flex-shrink-0
                        group-hover:bg-brand-green transition-colors duration-200">
              <svg class="w-5 h-5 text-brand-green group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-grey font-medium uppercase tracking-widest mb-0.5">WhatsApp</p>
              <p class="text-ink font-semibold group-hover:text-brand-green transition-colors">{site.whatsapp}</p>
            </div>
          </a>

          <!-- Location -->
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-brand-blue/8 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-grey font-medium uppercase tracking-widest mb-0.5">Based in</p>
              <p class="text-ink font-semibold">{site.location}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div data-animate data-delay="200">
        <form
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="bg-white rounded-2xl p-8 shadow-card"
          novalidate
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            <!-- Name -->
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-sm font-semibold text-ink">Name <span class="text-brand-green" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="Your name"
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink placeholder:text-brand-grey/50
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200"
              />
            </div>

            <!-- Business -->
            <div class="flex flex-col gap-1.5">
              <label for="business" class="text-sm font-semibold text-ink">Business</label>
              <input
                type="text"
                id="business"
                name="business"
                autocomplete="organization"
                placeholder="Your company"
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink placeholder:text-brand-grey/50
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-sm font-semibold text-ink">Email <span class="text-brand-green" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink placeholder:text-brand-grey/50
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200"
              />
            </div>

            <!-- WhatsApp -->
            <div class="flex flex-col gap-1.5">
              <label for="whatsapp" class="text-sm font-semibold text-ink">WhatsApp number</label>
              <input
                type="tel"
                id="whatsapp"
                name="whatsapp"
                autocomplete="tel"
                placeholder="+263 77 ..."
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink placeholder:text-brand-grey/50
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200"
              />
            </div>

            <!-- Service -->
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label for="service" class="text-sm font-semibold text-ink">Service interested in</label>
              <select
                id="service"
                name="service"
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink bg-white
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200 cursor-pointer"
              >
                <option value="">— Select a service —</option>
                {serviceOptions.map(s => <option value={s}>{s}</option>)}
                <option value="Not sure yet">Not sure yet — let's chat</option>
              </select>
            </div>

            <!-- Message -->
            <div class="sm:col-span-2 flex flex-col gap-1.5">
              <label for="message" class="text-sm font-semibold text-ink">Message <span class="text-brand-green" aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows={4}
                placeholder="Tell us about your business and what you'd like to achieve…"
                class="rounded-lg border border-brand-blue/15 px-4 py-2.5 text-sm text-ink placeholder:text-brand-grey/50
                       focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue
                       transition-colors duration-200 resize-y"
              ></textarea>
            </div>

          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="mt-5 w-full bg-brand-blue text-white px-7 py-3.5 rounded-xl font-semibold text-base
                   hover:bg-brand-green focus-visible:ring-2 focus-visible:ring-brand-blue focus-visible:ring-offset-2
                   transition-colors duration-200 active:scale-[0.98] shadow-btn"
          >
            Send message
            <span class="inline-block ml-2 w-1.5 h-1.5 rounded-full bg-white/60 align-middle" aria-hidden="true"></span>
          </button>

          <p class="mt-3 text-center text-xs text-brand-grey/60">
            We'll reply within one business day.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

---
<section id="why-benfort" class="bg-white py-24 lg:py-32" aria-labelledby="why-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="max-w-xl mb-16" data-animate>
      <div class="flex items-center gap-2 mb-4">
        <span class="w-2 h-2 rounded-full bg-brand-green" aria-hidden="true"></span>
        <span class="text-brand-green font-semibold text-sm uppercase tracking-widest">Why us</span>
      </div>
      <h2
        id="why-heading"
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-ink tracking-display leading-tight mb-4"
      >
        Why Benfort
      </h2>
      <p class="text-brand-grey text-lg leading-body">
        Here's how we actually work — and why it matters to the businesses we work with.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {whyBenfort.map((item, i) => (
        <div
          class="group bg-light rounded-xl p-7 shadow-card hover:shadow-card-hover transition-shadow duration-300"
          data-animate
          data-delay={String(Math.min(i * 100, 400))}
        >
          <!-- Icon -->
          <div class="w-11 h-11 rounded-xl bg-brand-blue/8 flex items-center justify-center mb-5
                      group-hover:bg-brand-green group-hover:text-white transition-colors duration-300">
            <svg
              class="w-5 h-5 text-brand-blue group-hover:text-white transition-colors duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.8"
              stroke="currentColor"
              aria-hidden="true"
              set:html={icons[i]}
            />
          </div>

          <h3 class="font-black text-brand-blue text-base mb-2 flex items-center gap-2">
            {item.title}
          </h3>
          <p class="text-brand-grey text-sm leading-body">{item.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
